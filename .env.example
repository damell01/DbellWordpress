# Copy this file to .env and fill in your SMTP credentials.
# .env is listed in .gitignore and will NOT be committed.

# ── SMTP Settings ──────────────────────────────────────────────────────────
# Gmail example:  smtp.gmail.com  / port 587 / tls / your-address@gmail.com
# Outlook:        smtp.office365.com / 587 / tls
# Custom hosting: mail.yourdomain.com / 465 / ssl

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ── From / Reply-To ────────────────────────────────────────────────────────
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=DBell Creations

# ── Admin inbox (receives all form submissions) ────────────────────────────
ADMIN_EMAIL=dbellcreations@gmail.com

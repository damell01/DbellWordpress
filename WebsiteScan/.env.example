APP_NAME=DBell Website Scanner
# If scanner is hosted at https://www.dbellcreations.com/WebsiteScan, set APP_URL to:
APP_URL=https://yourdomain.com/WebsiteScan
APP_ENV=production
APP_DEBUG=false
APP_DEBUG_LOG=true
APP_DEBUG_TOKEN=
APP_KEY=change_this_to_a_random_32_char_string

DB_HOST=localhost
DB_PORT=3306
DB_NAME=sitescope
DB_USER=root
DB_PASS=

MAIL_DRIVER=smtp
MAIL_FROM=no-reply@yourdomain.com
MAIL_FROM_NAME=DBell Website Scanner

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_ENCRYPTION=tls

GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_PAGESPEED_API_KEY=your-pagespeed-api-key

ADMIN_EMAIL=dbellcreations@gmail.com

RATE_LIMIT_AUDITS=5
RATE_LIMIT_WINDOW=3600

SESSION_LIFETIME=7200
